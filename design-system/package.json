{
  "name": "@nellie/design-system",
  "version": "1.0.0",
  "private": true,
  "description": "Nellie Connect design system: the real React components behind the marketing site, for use in claude.ai/design.",
  "type": "module",
  "module": "dist/index.es.js",
  "main": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "gen:media": "node gen-media.mjs",
    "build": "node gen-media.mjs && tsc -p tsconfig.json && node build.mjs"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "esbuild": "^0.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3"
  }
}
